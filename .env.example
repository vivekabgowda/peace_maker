# Root .env template for local development.
# Copy to `.env` (git-ignored). Full reference: infra/env/.env.dev.example
BKN_DB_USER=bkn
BKN_DB_PASSWORD=bkn
BKN_DB_NAME=bkn
BKN_JWT_SECRET_KEY=dev-secret-change-me-1234567890

# Market data: "simulated" (default, no broker) or "zerodha" (live Kite data).
BKN_MARKET_PROVIDER=simulated

# Paper trading + automatic performance reports (Sprint 7) — advisory only.
BKN_PAPER_TRADING_ENABLED=true
BKN_REPORT_SCHEDULER_ENABLED=true

# Only needed for live data (BKN_MARKET_PROVIDER=zerodha) — see infra/env/.env.dev.example.
BKN_ZERODHA_API_KEY=
BKN_ZERODHA_API_SECRET=
BKN_BROKER_ENC_KEY=
