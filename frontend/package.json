{
  "name": "bkn-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "BKN AI Capital — frontend (Next.js)",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "cd .. && husky frontend/.husky || true"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings 0"
    ],
    "*.{json,css,md}": "prettier --write"
  },
  "dependencies": {
    "@tanstack/react-query": "5.59.15",
    "clsx": "2.1.1",
    "lightweight-charts": "^4.2.3",
    "next": "14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "2.5.4",
    "zustand": "4.5.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.6.2",
    "@testing-library/react": "16.0.1",
    "@types/node": "20.16.11",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.0",
    "@vitejs/plugin-react": "4.3.2",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.35",
    "eslint-config-prettier": "9.1.0",
    "husky": "^9.1.6",
    "jsdom": "25.0.1",
    "lint-staged": "^15.2.10",
    "postcss": "8.4.47",
    "prettier": "3.3.3",
    "prettier-plugin-tailwindcss": "0.6.8",
    "tailwindcss": "3.4.14",
    "typescript": "5.6.3",
    "vitest": "2.1.3"
  },
  "engines": {
    "node": ">=20"
  }
}
