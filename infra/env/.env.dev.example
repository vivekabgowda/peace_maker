# ---------------------------------------------------------------------------
# BKN AI Capital — development environment (copy to ./.env at the repo root).
# Safe placeholder values only; never commit a real .env.
# ---------------------------------------------------------------------------

# Database (compose)
BKN_DB_USER=bkn
BKN_DB_PASSWORD=bkn
BKN_DB_NAME=bkn

# Backend
BKN_ENV=local
BKN_DEBUG=true
BKN_LOG_JSON=false
BKN_DATABASE_URL=postgresql+asyncpg://bkn:bkn@postgres:5432/bkn
BKN_REDIS_URL=redis://redis:6379/0
BKN_JWT_SECRET_KEY=dev-secret-change-me-1234567890
BKN_ACCESS_TOKEN_EXPIRE_MINUTES=15
BKN_REFRESH_TOKEN_EXPIRE_DAYS=30
BKN_CORS_ORIGINS=http://localhost:3000

# Seed (optional)
BKN_SEED_ADMIN_EMAIL=admin@bkn.local
BKN_SEED_ADMIN_PASSWORD=ChangeMe!123

# Frontend
NEXT_PUBLIC_API_BASE_URL=/api/v1

# --- Market data (Sprint 2) ---
BKN_MARKET_FEED_ENABLED=true
BKN_MARKET_PROVIDER=simulated
BKN_MARKET_TICK_INTERVAL=1.0
BKN_OPTION_CHAIN_UNDERLYINGS=NIFTY,BANKNIFTY
NEXT_PUBLIC_WS_URL=ws://localhost:8000/api/v1/ws
