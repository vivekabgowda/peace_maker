# ---------------------------------------------------------------------------
# BKN AI Capital — PRODUCTION environment (Hostinger VPS).
# Copy to the VPS as `.env` (chmod 600). Fill EVERY value with a real secret.
# Never commit the populated file. Rotate secrets periodically.
# ---------------------------------------------------------------------------

# Runtime
BKN_ENV=production
BKN_LOG_JSON=true

# --- Database (use a strong, unique password) ------------------------------
BKN_DB_USER=bkn
BKN_DB_PASSWORD=__CHANGE_ME_STRONG_DB_PASSWORD__
BKN_DB_NAME=bkn
BKN_DATABASE_URL=postgresql+asyncpg://bkn:__CHANGE_ME_STRONG_DB_PASSWORD__@postgres:5432/bkn

# --- Redis -----------------------------------------------------------------
BKN_REDIS_PASSWORD=__CHANGE_ME_STRONG_REDIS_PASSWORD__
BKN_REDIS_URL=redis://:__CHANGE_ME_STRONG_REDIS_PASSWORD__@redis:6379/0

# --- Security --------------------------------------------------------------
# Generate with:  openssl rand -hex 32
BKN_JWT_SECRET_KEY=__CHANGE_ME_64_HEX_CHARS__
BKN_ACCESS_TOKEN_EXPIRE_MINUTES=15
BKN_REFRESH_TOKEN_EXPIRE_DAYS=30

# --- CORS (the public site origin) -----------------------------------------
BKN_CORS_ORIGINS=https://bkn.example.com

# --- Images (set by CI to the released tags) -------------------------------
BKN_BACKEND_IMAGE=ghcr.io/OWNER/bkn-backend:latest
BKN_FRONTEND_IMAGE=ghcr.io/OWNER/bkn-frontend:latest

# --- Backups (off-VPS destination; see scripts/backup.sh) ------------------
BKN_BACKUP_DIR=/opt/bkn/backups
